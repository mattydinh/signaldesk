# Database (required). Prisma uses POSTGRES_PRISMA_URL (set automatically by Supabase–Vercel integration).
# Local: get pooler URI from Supabase → Project Settings → Database → Connection string → URI (Session pooler, port 6543).
# Use us-east-1 pooler for Supabase (match your project's region in Project Settings → General).
POSTGRES_PRISMA_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require"

# EIA (weekly fundamentals): crude inventory. Get key at eia.gov/opendata/register.php
# EIA_API_KEY=

# Baker Hughes rig count (optional): OilPriceAPI has rig count. Get key at oilpriceapi.com
# OILPRICE_API_KEY=

# News API (for scheduled ingestion) — get key at newsapi.org
# NEWS_API_KEY=

# Cron: secret for /api/cron/ingest-news (query ?secret= or Authorization: Bearer)
# CRON_SECRET=

# Ingest API: if set, POST /api/news/ingest requires x-api-key or Authorization: Bearer
# INGEST_API_KEY=

# Dashboard: if set, /dashboard requires login (password)
# DASHBOARD_PASSWORD=

# OpenAI (for AI analysis)
# OPENAI_API_KEY=sk-...