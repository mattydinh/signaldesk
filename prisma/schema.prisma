// SignalDesk - Financial & Political Intelligence
// PostgreSQL (Supabase)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Source {
  id        String   @id @default(cuid())
  name      String   // e.g. "Reuters", "Politico"
  slug      String   @unique
  baseUrl   String?
  createdAt DateTime @default(now())
  articles  Article[]
}

model Article {
  id            String    @id @default(cuid())
  externalId    String?   // id from upstream API
  sourceId      String
  source        Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  title         String
  summary       String?   @db.Text
  url           String?
  publishedAt   DateTime?
  rawPayload    Json?     // original API response for debugging
  // NLP / intelligence (populated by analyze)
  entities      String[]  @default([]) // extracted entities
  topics        String[]  @default([]) // extracted topics
  categories    String[]  @default([]) // e.g. Finance, Crypto, Political, Geopolitics, War & Conflict, Technology, Regulation, Markets, Energy
  implications  String?   @db.Text     // short summary (legacy)
  opportunities String[]  @default([]) // concrete opportunities / recommendations
  forShareholders String?  @db.Text    // what this means for shareholders
  forInvestors   String?   @db.Text    // what this means for investors / markets
  forBusiness    String?   @db.Text    // what this means for business leaders
  // embedding  vector(1536) — add with pgvector extension when ready
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([sourceId])
  @@index([publishedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model WeeklySummary {
  id                 String   @id @default(cuid())
  weekStart          DateTime
  weekEnd            DateTime
  title              String
  summaryText        String   @db.Text
  keyTrends          Json     // array of strings
  impactedSectors    Json     // array of { sector, direction, reasoning }
  geopoliticalScore Float?
  investorSignal     Json     // { geopoliticalAssessment?, investorImplications? }
  createdAt          DateTime @default(now())

  @@unique([weekStart])
  @@index([weekStart(sort: Desc)])
}

// ---- ML pipeline (unified event model + derived signals) ----

model Event {
  id          String   @id @default(cuid())
  source      String   // "news" | "twitter"
  publishedAt DateTime @map("published_at")
  rawText     String   @db.Text @map("raw_text")
  cleanText   String?  @db.Text @map("clean_text")
  entities    String[] @default([])
  categories  String[] @default([])
  url         String?
  createdAt   DateTime @default(now()) @map("created_at")
  features   EventFeature?

  @@index([publishedAt(sort: Desc)])
  @@index([source])
}

model EventFeature {
  eventId               String   @id @map("event_id")
  event                 Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sentimentScore        Float    @map("sentiment_score")
  sentimentConfidence   Float    @map("sentiment_confidence")
  regulationScore       Float    @map("regulation_score")
  geopoliticalRiskScore Float    @map("geopolitical_risk_score")
  createdAt             DateTime @default(now()) @map("created_at")
}

model DailyTopicMetric {
  topic            String   @map("topic")
  date             DateTime @db.Date @map("date")
  articleCount     Int      @map("article_count")
  avgSentiment     Float    @map("avg_sentiment")
  sentimentStd     Float    @map("sentiment_std")
  sentimentChange7d Float   @map("sentiment_change_7d")
  volumeZscore     Float    @map("volume_zscore")

  @@id([topic, date])
  @@index([date(sort: Desc)])
}

model DerivedSignal {
  date        DateTime @db.Date @map("date")
  signalName  String   @map("signal_name")
  value       Float    @map("value")
  zscore      Float    @map("zscore")
  confidence  Float    @map("confidence")

  @@id([date, signalName])
  @@index([signalName])
  @@index([date(sort: Desc)])
}

model MarketPrice {
  ticker      String   @map("ticker")
  date        DateTime @db.Date @map("date")
  open        Float    @map("open")
  high        Float    @map("high")
  low         Float    @map("low")
  close       Float    @map("close")
  volume      BigInt   @map("volume")
  dailyReturn Float    @map("daily_return")

  @@id([ticker, date])
  @@index([date(sort: Desc)])
}

model RegimeSnapshot {
  date       DateTime @id @db.Date @map("date")
  regime     String   @map("regime")
  confidence Float    @map("confidence")
  drivers    String[] @default([]) @map("drivers")
}

model BacktestResult {
  signalName          String   @map("signal_name")
  ticker              String   @map("ticker")
  startDate           DateTime @db.Date @map("start_date")
  endDate             DateTime @db.Date @map("end_date")
  cumulativeReturn    Float    @map("cumulative_return")
  annualizedReturn    Float    @map("annualized_return")
  annualizedVolatility Float   @map("annualized_volatility")
  sharpe              Float    @map("sharpe")
  maxDrawdown         Float    @map("max_drawdown")
  turnover            Float    @map("turnover")
  hitRate             Float    @map("hit_rate")

  @@id([signalName, ticker, startDate, endDate])
}

// ---- Weekly fundamentals (EIA inventory, Baker Hughes rig count) ----
// Forward-filled to daily in pipeline when computing oil signals.
model WeeklyFundamental {
  series    String   @map("series")   // e.g. "eia_crude_inventory_change", "baker_hughes_rig_count"
  reportDate DateTime @db.Date @map("report_date")  // week-ending date of the report
  value     Float    @map("value")
  createdAt DateTime @default(now()) @map("created_at")

  @@id([series, reportDate])
  @@index([series, reportDate(sort: Desc)])
}
